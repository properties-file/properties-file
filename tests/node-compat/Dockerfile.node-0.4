# Verifies that the compiled output works on Node.js 0.4.0 (February 2011).
# This is the first stable Node.js release with ES5 support.
#
# Usage:
#   docker build --platform linux/amd64 -f tests/node-compat/Dockerfile.node-0.4 .
#
# The Node.js binary is compiled from source without SSL (our parser
# doesn't use crypto). This takes ~12 minutes on first build but the
# Docker layer is cached for subsequent runs.

FROM ubuntu:12.04 AS builder

RUN sed -i 's|archive.ubuntu.com|old-releases.ubuntu.com|g' /etc/apt/sources.list \
    && sed -i 's|security.ubuntu.com|old-releases.ubuntu.com|g' /etc/apt/sources.list \
    && apt-get update && apt-get install -y \
    build-essential python curl \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
RUN curl -kL https://nodejs.org/dist/v0.4.0/node-v0.4.0.tar.gz | tar xz

WORKDIR /build/node-v0.4.0
RUN ./configure --prefix=/usr/local --without-ssl && make && make install

# Final stage — only the compiled binary + test files.
FROM ubuntu:12.04

RUN sed -i 's|archive.ubuntu.com|old-releases.ubuntu.com|g' /etc/apt/sources.list \
    && sed -i 's|security.ubuntu.com|old-releases.ubuntu.com|g' /etc/apt/sources.list \
    && apt-get update && apt-get install -y libstdc++6 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /usr/local/bin/node /usr/local/bin/node

COPY dist/cjs /dist/cjs
COPY tests/node-compat/test.js /test.js

RUN node /test.js
